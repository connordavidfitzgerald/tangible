---
import Layout from '@layouts/Layout.astro';
import Button from '@components/Button/Button.astro';
import Image from '@components/Image/Image.astro';
import { Picture } from 'astro:assets';
import chalkboard from '@images/Home_about.jpg';
import RevealHeader from '@components/RevealHeader/RevealHeader.astro';
import ContactFooter from '@components/ContactFooter/ContactFooter.astro';
import SplitReveal from '@components/SplitReveal/SplitReveal.astro';
import FadeUp from '@components/FadeUp/FadeUp.astro';

import LottieAnimation from 'astro-integration-lottie/Lottie.astro';
import plantAnimationUrl from '@images/plant.json?url';

import img1 from '@images/tangible1.jpg';
import img2 from '@images/tangible2.jpg';
import img3 from '@images/tangible3.jpg';
import img4 from '@images/tangible4.jpg';
import img5 from '@images/tangible5.jpg';

import img6 from '@images/Tangible0797.jpg';
import img7 from '@images/LEADER.jpg';

import mob1 from '@images/mob_tang1.jpg';
import mob2 from '@images/mob_tang2.jpg';
import mob3 from '@images/mob_tang3.jpg';
import mob4 from '@images/mob_tang4.jpg';
import mob5 from '@images/mob_tang5.jpg';

import content from '../../content/home.json';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = lang === 'en' ? content.en : content.fr;

// Hero fonts are a design decision kept out of the CMS
const heroFonts = ['formula', 'editorial', 'editorial'] as const;
const entreprisesTitleFonts = ['formula', 'editorial'] as const;
const leadersTitleFonts = ['formula', 'editorial'] as const;
---

<Layout title="Tangible">
    <div
        class="hero-section relative flex min-h-200 w-full flex-col justify-end overflow-hidden pr-fluid-forty pb-fluid-270 pl-fluid-forty lg:aspect-1512/913 lg:min-h-0 lg:justify-center lg:pb-0"
    >
        <div class="hero-slideshow hidden brightness-80 sm:flex">
            <div class="hero-slide" style="z-index: 5; animation-delay: 0s" aria-hidden="true">
                <Picture src={img1} alt="" layout="full-width" />
            </div>
            <div class="hero-slide" style="z-index: 4; animation-delay: 4s" aria-hidden="true">
                <Picture src={img2} alt="" layout="full-width" loading="lazy" />
            </div>
            <div class="hero-slide" style="z-index: 3; animation-delay: 8s" aria-hidden="true">
                <Picture src={img3} alt="" layout="full-width" loading="lazy" />
            </div>
            <div class="hero-slide" style="z-index: 2; animation-delay: 12s" aria-hidden="true">
                <Picture src={img4} alt="" layout="full-width" loading="lazy" />
            </div>
            <div class="hero-slide" style="z-index: 1; animation-delay: 16s" aria-hidden="true">
                <Picture src={img5} alt="" layout="full-width" loading="lazy" />
            </div>
        </div>
        <div class="hero-slideshow mob-version flex brightness-80 sm:hidden">
            <div class="hero-slide" style="z-index: 5; animation-delay: 0s" aria-hidden="true">
                <Picture src={mob1} alt="" layout="full-width" />
            </div>
            <div class="hero-slide" style="z-index: 4; animation-delay: 4s" aria-hidden="true">
                <Picture src={mob2} alt="" layout="full-width" loading="lazy" />
            </div>
            <div class="hero-slide" style="z-index: 3; animation-delay: 8s" aria-hidden="true">
                <Picture src={mob3} alt="" layout="full-width" loading="lazy" />
            </div>
            <div class="hero-slide" style="z-index: 2; animation-delay: 12s" aria-hidden="true">
                <Picture src={mob4} alt="" layout="full-width" loading="lazy" />
            </div>
            <div class="hero-slide" style="z-index: 1; animation-delay: 16s" aria-hidden="true">
                <Picture src={mob5} alt="" layout="full-width" loading="lazy" />
            </div>
        </div>

        <div class="relative z-10">
            <RevealHeader
                delay={0.25}
                textColor={'#FFFFFF'}
                lines={[t.heroLine1, t.heroLine2, t.heroLine3].map((text, i) => ({
                    text,
                    font: heroFonts[i]
                }))}
            />
        </div>
    </div>

    <div
        class="desktop-version grid h-fit min-h-[500px] grid-cols-12 gap-fluid-twenty bg-offwhite pt-fluid-eighty pr-fluid-forty pb-fluid-eighty pl-fluid-forty"
    >
        <div class="col-span-4 min-h-full overflow-clip pr-fluid-twenty">
            <FadeUp>
                <Picture
                    src={chalkboard}
                    class="aspect-444/668 min-h-[500px] object-cover"
                    layout="full-width"
                    alt="chalkboard"
                    loading="lazy"
                />
            </FadeUp>
        </div>
        <div class="col-span-8 flex grow flex-col">
            <div
                class="font-radio flex flex-row items-center justify-center border-b border-b-perle pb-3 text-[0.875rem] uppercase lg:text-[1rem]"
            >
                {t.aboutSectionLabel}
            </div>

            <div
                class="desktop-version flex grow flex-col justify-between pt-fluid-eighty pr-[3.78rem] pl-[3.78rem]"
            >
                <p class="text-test leading-[120%] font-light tracking-[3%]">
                    <span class="font-bold text-bronze">Tangible</span>
                    {' '}{t.aboutBody}
                </p>
            </div>
            <div
                class="desktop-version flex w-full flex-row items-center justify-center pb-fluid-forty"
            >
                <Button class="text-body-sm tracking-[3%] uppercase" href="/about">
                    {t.aboutButton}
                </Button>
            </div>
        </div>
    </div>

    <div class="mob-version grid h-fit min-h-[500px] grid-cols-8 gap-mob-16 bg-offwhite p-mob-16">
        <div
            class="font-radio text-[0.875rem]tracking-[3%] col-span-8 flex flex-row items-center justify-center border-b border-b-perle pt-mob-64 pr-mob-16 pb-mob-16 pl-mob-16 uppercase"
        >
            {t.aboutSectionLabel}
        </div>

        <div class="col-span-6 col-start-2 min-h-full pt-mob-64">
            <FadeUp>
                <Picture
                    src={chalkboard}
                    class="aspect-267/343 object-cover"
                    layout="full-width"
                    alt="chalkboard"
                />
            </FadeUp>
        </div>
        <div class="col-span-8 flex flex-col pt-mob-64 pb-mob-64">
            <div class="flex flex-col gap-mob-32">
                <p class="text-mob-body leading-[120%] font-light tracking-[3%]">
                    <span class="font-bold text-bronze">Tangible</span>
                    {' '}{t.aboutBody}
                </p>
                <div class="flex w-full flex-row items-center justify-center">
                    <Button class="text-body-sm tracking-[3%] uppercase" href="/about">
                        {t.aboutButton}
                    </Button>
                </div>
            </div>
        </div>
    </div>

    <div
        class="desktop-version mx-fluid-twenty grid aspect-1512/902 h-fit grid-cols-12 items-center justify-center gap-fluid-twenty bg-yellow pt-fluid-eighty pr-fluid-forty pb-fluid-eighty pl-fluid-forty"
    >
        <div class="col-span-6 col-start-2 flex flex-col justify-center leading-[110%]">
            <SplitReveal class="heading-lg font-radio leading-[110%] font-normal tracking-[0%]">
                {t.missionQuote}
            </SplitReveal>
        </div>
        <div class="col-span-5 col-start-8">
            <div class="h-full w-full mix-blend-multiply">
                <LottieAnimation src={plantAnimationUrl} autoplay={true} loop={true} />
            </div>
        </div>
    </div>

    <div
        class="mob-version mx-fluid-forty grid grid-cols-8 items-center justify-center gap-mob-16 bg-yellow pt-mob-64 pr-mob-16 pb-mob-64 pl-mob-16"
    >
        <div class="col-span-6 col-start-2 flex flex-col gap-mob-64">
            <div class="w-full mix-blend-multiply">
                <LottieAnimation src={plantAnimationUrl} autoplay={true} loop={true} />
            </div>
            <h1
                class="font-radio flex flex-col justify-center text-mob-md leading-[105%] font-normal tracking-[0%]"
            >
                {t.missionQuote}
            </h1>
        </div>
    </div>

    <div
        class="desktop-version flex h-fit flex-col bg-offwhite pt-fluid-forty pr-fluid-forty pb-fluid-eighty pl-fluid-forty"
    >
        <div
            class="font-radio flex w-full flex-row items-center justify-center border-b border-b-perle pb-3 text-[1rem] tracking-[3%] uppercase"
        >
            {t.programsSectionLabel}
        </div>
        <div
            class="relative grid grid-cols-12 gap-fluid-twenty bg-offwhite pt-fluid-forty pr-fluid-forty pl-fluid-forty"
        >
        </div>
    </div>

    <div class="mob-version flex h-fit flex-col bg-offwhite pt-mob-64 pr-mob-16 pl-mob-16">
        <div
            class="font-radio flex w-full flex-row items-center justify-center border-b border-b-perle pb-3 text-[0.875rem] tracking-[3%] uppercase"
        >
            {t.programsSectionLabel}
        </div>
        <div
            class="relative grid grid-cols-8 gap-mob-16 border-b border-perle bg-offwhite pt-fluid-forty"
        >
            <div class="col-span-8 pt-mob-64 pb-mob-16">
                <RevealHeader
                    lines={[t.entreprisesTitle1, t.entreprisesTitle2].map((text, i) => ({
                        text,
                        font: entreprisesTitleFonts[i]
                    }))}
                />
            </div>
            <Image src={img6} class="aspect-267/367.43 col-span-6 col-start-2" />
            <div class="col-span-6 col-start-2 flex flex-col justify-start gap-0 pt-mob-16">
                <p class="pb-fluid-forty text-mob-caption leading-[120%] tracking-[3%]">
                    {t.entreprisesBody}
                    <br /><br />
                    <span class="font-bold text-bronze">{t.entreprisesResult.split(':')[0]}:</span>{
                        t.entreprisesResult.split(':').slice(1).join(':')
                    }
                </p>
                <div class="flex w-full flex-row items-center justify-center pt-mob-16 pb-mob-64">
                    <Button
                        class="text-body-sm tracking-[3%] uppercase"
                        href="/services/entreprises">{t.entreprisesButton}</Button
                    >
                </div>
            </div>
        </div>
        <div
            class="relative grid grid-cols-8 gap-mob-16 border-b border-perle bg-offwhite pt-fluid-forty"
        >
            <div class="col-span-8 pt-mob-64 pb-mob-16">
                <RevealHeader
                    lines={[t.leadersTitle1, t.leadersTitle2].map((text, i) => ({
                        text,
                        font: leadersTitleFonts[i]
                    }))}
                />
            </div>
            <Image src={img7} class="aspect-267/367.43 col-span-6 col-start-2" />
            <div class="col-span-6 col-start-2 flex flex-col justify-start gap-0 pt-mob-16">
                <p class="pb-fluid-forty text-mob-caption leading-[120%] tracking-[3%]">
                    {t.leadersBody}
                    <br /><br />
                    <span class="font-bold text-bronze">{t.leadersAmbition.split(':')[0]}:</span>{
                        t.leadersAmbition.split(':').slice(1).join(':')
                    }
                </p>
                <div class="flex w-full flex-row items-center justify-center pt-mob-16 pb-mob-64">
                    <Button class="uppercase" href="/services/leaders">{t.leadersButton}</Button>
                </div>
            </div>
        </div>
    </div>

    <div
        class="desktop-version relative grid h-fit grid-cols-12 gap-fluid-twenty bg-offwhite pt-fluid-eighty pr-fluid-forty pb-fluid-forty pl-fluid-forty"
    >
        <div class="col-span-4 flex flex-col overflow-clip pr-fluid-twenty">
            <Image src={img6} class="h-full" />
        </div>
        <div
            class="col-span-8 flex h-full flex-col items-start gap-fluid-forty overflow-hidden border-b border-b-perle pr-fluid-sixty pl-fluid-sixty"
        >
            <RevealHeader
                lines={[t.entreprisesTitle1, t.entreprisesTitle2].map((text, i) => ({
                    text,
                    font: entreprisesTitleFonts[i]
                }))}
            />
            <div class="flex flex-col justify-end gap-0">
                <p class="pb-fluid-forty text-body-caption leading-[120%] tracking-[3%]">
                    {t.entreprisesBody}
                    <br /><br />
                    <span class="font-bold text-bronze">{t.entreprisesResult.split(':')[0]}:</span>{
                        t.entreprisesResult.split(':').slice(1).join(':')
                    }
                </p>
                <div class="flex w-full flex-row items-center justify-center pb-fluid-forty">
                    <Button
                        class="text-body-sm tracking-[3%] uppercase"
                        href="/services/entreprises">{t.entreprisesButton}</Button
                    >
                </div>
            </div>
        </div>
    </div>

    <div
        class="desktop-version relative grid h-fit grid-cols-12 gap-fluid-twenty border-b border-b-perle bg-offwhite pt-fluid-eighty pr-fluid-forty pb-fluid-eighty pl-fluid-forty"
    >
        <div
            class="col-span-8 flex h-full flex-col items-start gap-fluid-forty overflow-hidden pr-fluid-sixty pl-fluid-sixty"
        >
            <RevealHeader
                lines={[t.leadersTitle1, t.leadersTitle2].map((text, i) => ({
                    text,
                    font: leadersTitleFonts[i]
                }))}
            />
            <div class="flex flex-col justify-end gap-0">
                <p class="pb-fluid-forty text-body-caption leading-[120%] tracking-[3%]">
                    {t.leadersBody}
                    <br /><br />
                    <span class="font-bold text-bronze">{t.leadersAmbition.split(':')[0]}:</span>{
                        t.leadersAmbition.split(':').slice(1).join(':')
                    }
                </p>
                <div class="flex w-full flex-row items-center justify-center pb-fluid-forty">
                    <Button class="text-body-sm tracking-[3%] uppercase" href="/services/leaders">
                        {t.leadersButton}
                    </Button>
                </div>
            </div>
        </div>
        <div class="col-span-4 overflow-clip pl-fluid-twenty">
            <Image src={img7} class="aspect-444/668 h-full" />
        </div>
    </div>

    <ContactFooter heading={t.contactFooterHeading} />
</Layout>

<style>
    .hero-section {
        background: #1a1a1a;
    }

    .hero-slideshow {
        position: absolute;
        inset: 0;
        z-index: 0;
    }

    .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 1;
        animation: hero-fade 20s ease-out infinite;
    }

    :global(.hero-slide picture),
    :global(.hero-slide img) {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        z-index: 6;
        background: rgba(0, 0, 0, 0.35);
        pointer-events: none;
    }

    @keyframes hero-fade {
        0% {
            opacity: 1;
        }
        15% {
            opacity: 1;
        }
        20% {
            opacity: 0;
        }
        95% {
            opacity: 0;
        }
        100% {
            opacity: 1;
        }
    }
</style>
