---
import Layout from '@layouts/Layout.astro';
import { Picture } from 'astro:assets';
import RevealHeader from '@components/RevealHeader/RevealHeader.astro';
import SplitReveal from '@components/SplitReveal/SplitReveal.astro';
import Button from '@components/Button/Button.astro';

import building from '@images/AH1A3167.jpg';
import mob from '@images/building-mob.jpg';

import content from '../../content/contact.json';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = lang === 'en' ? content.en : content.fr;

const heroFonts = ['formula', 'formula', 'editorial', 'editorial'] as const;
---

<Layout title="Tangible — Contact">
    <div
        class="flex aspect-393/852 max-h-dvh flex-col justify-end overflow-hidden bg-offwhite pr-fluid-forty pl-fluid-forty sm:aspect-1512/902 sm:justify-center sm:pb-0"
    >
        <div class="absolute right-0 left-0 z-0 aspect-393/852 object-cover sm:aspect-1512/902">
            <Picture
                alt="A clipboard and paper"
                src={building}
                layout="full-width"
                class="hidden w-full object-cover brightness-75 sm:flex"
            />
            <Picture
                alt="A clipboard and paper"
                src={mob}
                layout="full-width"
                class="flex w-full object-cover brightness-75 sm:hidden"
            />
        </div>
        <div class="pb-fluid-270 sm:pb-0">
            <RevealHeader
                delay={0.25}
                textColor="#FFFFFF"
                lines={[
                    t.heroLine1,
                    t.heroLine2,
                    t.heroLine3,
                    (t as { heroLine4?: string }).heroLine4
                ]
                    .filter((text): text is string => Boolean(text))
                    .map((text, i) => ({
                        text,
                        font: heroFonts[i]
                    }))}
            />
        </div>
    </div>

    <div
        class="grid h-fit grid-cols-12 gap-fluid-twenty bg-perle pt-fluid-160 pr-fluid-forty pb-fluid-160 pl-fluid-forty"
    >
        <div
            class="col-span-12 flex h-full flex-col justify-start gap-fluid-eighty sm:col-span-8 sm:col-start-3"
        >
            <div class="flex flex-col gap-fluid-forty pt-32 pb-32 sm:pt-0 sm:pb-0">
                <SplitReveal
                    class="w-full text-mob-body leading-[120%] font-bold tracking-[2%] text-bronze sm:text-body-md"
                >
                    {t.introBold}
                </SplitReveal>
                <div
                    class="flex flex-col gap-0 text-mob-body leading-[120%] font-light tracking-[2%] sm:gap-fluid-forty sm:text-body-md"
                >
                    <p class="pb-fluid-forty sm:pb-0">
                        {t.introBody}
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div
        class="grid grid-cols-12 bg-offwhite pt-16 pr-fluid-forty pb-32 pl-fluid-forty sm:pt-fluid-eighty sm:pb-fluid-270"
    >
        <div class="col-span-12 sm:col-span-8 sm:col-start-3">
            <form id="contact-form">
                <input
                    type="hidden"
                    name="access_key"
                    value="3cb859b7-eb03-4988-a1d8-38cf672ee0c8"
                />
                <label
                    for="name"
                    class="font-radio block text-sm text-body-sm tracking-[2%] uppercase opacity-75"
                >
                    {t.fieldName}
                </label>
                <input
                    type="text"
                    class="mb-5 w-full border-b border-b-black pt-1 pb-1 text-body-md outline-0"
                    name="name"
                    required
                />
                <label
                    for="email"
                    class="font-radio block text-sm text-body-sm tracking-[2%] uppercase opacity-75"
                >
                    {t.fieldEmail}
                </label>
                <input
                    type="email"
                    name="email"
                    class="mb-5 w-full border-b border-b-black pt-1 pb-1 text-body-md outline-0"
                    required
                />
                <label
                    for="phone"
                    class="font-radio block text-sm text-body-sm tracking-[2%] uppercase opacity-75"
                >
                    {t.fieldPhone}
                </label>
                <input
                    type="text"
                    name="phone"
                    class="mb-5 w-full border-b border-b-black pt-1 pb-1 text-body-md outline-0"
                    required
                />
                <label
                    for="message"
                    class="font-radio block text-sm text-body-sm tracking-[2%] uppercase opacity-75"
                >
                    {t.fieldMessage}
                </label>
                <textarea
                    name="message"
                    class="mb-5 w-full resize-none border-b border-b-black pt-1 pb-1 text-body-md outline-0"
                    required
                    rows="3"></textarea>
                <div class="flex h-fit flex-row items-center gap-fluid-twenty pb-fluid-forty">
                    <input
                        type="checkbox"
                        id="reserver"
                        name="reserver"
                        checked
                        class="aspect-square h-4.5 w-auto shrink-0 cursor-pointer appearance-none rounded-none border border-black bg-offwhite transition-colors checked:border-black checked:bg-black checked:bg-[url('data:image/svg+xml,%3Csvg%20viewBox%3D%220%200%2016%2016%22%20fill%3D%22white%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M12.207%204.793a1%201%200%200%201%200%201.414l-5%205a1%201%200%200%201-1.414%200l-2-2a1%201%200%200%201%201.414-1.414L6.5%209.086l4.293-4.293a1%201%200%200%201%201.414%200z%22%2F%3E%3C%2Fsvg%3E')] checked:bg-center checked:bg-no-repeat"
                    />
                    <label for="reserver" class="text-body-caption leading-[120%] tracking-[3%]">
                        {t.checkboxLabel}
                    </label>
                </div>
                <div class="flex flex-row justify-center">
                    <Button id="submit-btn" type="submit">{t.submitButton}</Button>
                </div>
            </form>
        </div>
    </div>
</Layout>
