---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<nav-bar style="display: contents;">
    <div
        id="navbar"
        class="fixed top-10 z-50 flex h-fit w-full flex-row justify-between bg-yellow pt-2 pr-mob-16 pb-2 pl-mob-16 md:pr-fluid-forty md:pl-fluid-forty"
    >
        <a href={translatePath('/')} class="relative z-10"
            ><Icon name="logo" class="h-fluid-thirty w-auto" /></a
        >

        <!-- Desktop nav items -->
        <div
            class="desktop-nav flex flex-row items-center gap-fluid-forty font-sans text-[1rem] tracking-[2%] uppercase"
        >
            <a class="hover-underline" href={translatePath('/about')}>{t('nav.about')}</a>
            <a class="hover-underline" href={translatePath('/programs')}>{t('nav.programs')}</a>
            <a
                class="hover-underline"
                href="https://www.cognito-app.com/coach/?askedByTenant=ten181110034803"
                >{t('nav.members')}</a
            >
            <a class="hover-underline" href={translatePath('/contact')}>{t('nav.contact')}</a>
            <a class="hover-underline" href={translatePath('/centre-iam')}>{t('nav.iam')}</a>
        </div>
        <div
            class="desktop-nav flex flex-row items-center gap-5 font-sans text-[1rem] tracking-[2%] uppercase"
        >
            <a
                href={translatePath(Astro.url.pathname, lang === 'en' ? 'fr' : 'en')}
                class="hover-underline">{lang === 'en' ? 'FR' : 'EN'}</a
            >
            <a class="hover-underline" href="https://www.app.taaars.com/b/roncherilus"
                >{t('nav.book')}</a
            >
        </div>

        <!-- Hamburger button (mobile only) -->
        <button id="hamburger" class="hamburger" aria-label="Toggle menu" aria-expanded="false">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </button>
    </div>

    <!-- Mobile menu overlay -->
    <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
        <nav class="mobile-nav gap-0 pr-mob-16 pl-mob-16">
            <a
                href={translatePath('/about')}
                class="flex w-full flex-col border-t border-white pt-mob-menu pb-mob-menu text-[2.1875rem]"
                >{t('nav.about')}</a
            >
            <a
                href={translatePath('/programs')}
                class="flex w-full flex-col border-t border-white pt-mob-menu pb-mob-menu text-[2.1875rem]"
                >{t('nav.programs')}</a
            >
            <a
                href="https://www.cognito-app.com/coach/?askedByTenant=ten181110034803"
                class="flex w-full flex-col border-t border-white pt-mob-menu pb-mob-menu text-[2.1875rem]"
                >{t('nav.members')}</a
            >
            <a
                href={translatePath('/contact')}
                class="flex w-full flex-col border-t border-white pt-mob-menu pb-mob-menu text-[2.1875rem]"
                >{t('nav.contact')}</a
            >
            <a
                href={translatePath('/centre-iam')}
                class="flex w-full flex-col border-t border-white pt-mob-menu pb-mob-menu text-[2.1875rem]"
                >{t('nav.iam')}</a
            >
            <a
                href="https://www.app.taaars.com/b/roncherilus"
                class="flex w-full flex-col border-t border-b border-white pt-mob-menu pb-mob-menu text-[2.1875rem]"
                >{t('nav.book')}</a
            >
            <a
                href={translatePath(Astro.url.pathname, lang === 'en' ? 'fr' : 'en')}
                class="w-full flex-col border-t border-white pt-mob-menu pb-mob-menu text-[1.5rem]"
                >{lang === 'en' ? 'FR' : 'EN'}</a
            >
        </nav>
    </div>
</nav-bar>

<style>
    /* ── Hamburger button ── */
    .hamburger {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        width: 30px;
        height: 30px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        position: relative;
        z-index: 200;
    }

    .bar {
        display: block;
        width: 30px;
        height: 1px;
        background-color: black;
        transition:
            transform 0.35s cubic-bezier(0.77, 0, 0.175, 1),
            opacity 0.25s ease;
        transform-origin: center;
    }

    /* X state */
    .hamburger.is-open .bar:nth-child(1) {
        transform: translateY(6px) rotate(45deg);
    }
    .hamburger.is-open .bar:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }
    .hamburger.is-open .bar:nth-child(3) {
        transform: translateY(-6px) rotate(-45deg);
    }

    /* ── Mobile menu overlay ── */
    .mobile-menu {
        position: fixed;
        inset: 0;
        background-color: var(--color-yellow); /* yellow — adjust to your yellow token */
        z-index: 40;
        display: flex;
        align-items: start;
        justify-content: start;
        padding-top: 10rem;
        overflow-x: hidden;
        overflow-y: auto;

        /* Hidden by default */
        opacity: 0;
        pointer-events: none;
        transform: translateY(-8px);
        transition:
            opacity 0.35s cubic-bezier(0.77, 0, 0.175, 1),
            transform 0.35s cubic-bezier(0.77, 0, 0.175, 1);
    }

    .mobile-menu.is-open {
        opacity: 1;
        pointer-events: all;
        transform: translateY(0);
    }

    .mobile-nav {
        display: flex;
        width: 100%;
        flex-direction: column;
        align-items: start;
    }

    .mobile-nav a {
        font-family: var(--font-sans, sans-serif);
        letter-spacing: 0%;
        line-height: 105%;
        color: black;
        text-decoration: none;
        position: relative;
    }

    /* ── Responsive ── */
    @media (max-width: 1160px) {
        .desktop-nav {
            display: none;
        }

        .hamburger {
            display: flex;
        }
    }
</style>

<script>
    class NavBar extends HTMLElement {
        connectedCallback() {
            const hamburger = this.querySelector('#hamburger');
            const mobileMenu = this.querySelector('#mobile-menu');

            if (!hamburger || !mobileMenu) return;

            // Forward wheel events into the overlay so trackpad/mouse scroll works
            // while the body is locked (fixed elements sit outside the normal scroll chain)
            mobileMenu.addEventListener(
                'wheel',
                (e) => {
                    e.preventDefault();
                    mobileMenu.scrollTop += (e as WheelEvent).deltaY;
                },
                { passive: false }
            );

            hamburger.addEventListener('click', () => {
                const isOpen = hamburger.classList.toggle('is-open');
                mobileMenu.classList.toggle('is-open', isOpen);
                hamburger.setAttribute('aria-expanded', String(isOpen));
                mobileMenu.setAttribute('aria-hidden', String(!isOpen));

                // Lock body so background page doesn't scroll behind the menu
                document.body.style.overflow = isOpen ? 'hidden' : '';
            });

            // Close menu when a link is clicked
            mobileMenu.querySelectorAll('a').forEach((link) => {
                link.addEventListener('click', () => {
                    hamburger.classList.remove('is-open');
                    mobileMenu.classList.remove('is-open');
                    hamburger.setAttribute('aria-expanded', 'false');
                    mobileMenu.setAttribute('aria-hidden', 'true');
                    document.body.style.overflow = '';
                });
            });
        }
    }

    if (!customElements.get('nav-bar')) {
        customElements.define('nav-bar', NavBar);
    }
</script>
