---
import Layout from '@layouts/Layout.astro';
import Button from '@components/Button/Button.astro';
import Image from '@components/Image/Image.astro';
import { Picture } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import chalkboard from '@images/Home_about.jpg';
import RevealHeader from '@components/RevealHeader/RevealHeader.astro';
import ContactFooter from '@components/ContactFooter/ContactFooter.astro';
import RevealImage from '@components/RevealHeader/RevealImage.astro';
import RevealBody from '@components/RevealHeader/RevealBody.astro';

import img1 from '@images/tangible1.jpg';
import img2 from '@images/tangible2.jpg';
import img3 from '@images/tangible3.jpg';
import img4 from '@images/tangible4.jpg';
import img5 from '@images/tangible5.jpg';
---

<Layout title="Tangible">
    <div
        class="hero-section relative flex h-dvh max-h-dvh flex-col justify-end overflow-hidden pr-fluid-forty pb-fluid-270 pl-fluid-forty lg:max-h-300 lg:min-h-200 lg:justify-center lg:pb-0"
    >
        <!-- Crossfade background slideshow -->
        <div class="hero-slideshow brightness-80">
            <div class="hero-slide" style="z-index: 5; animation-delay: 0s" aria-hidden="true">
                <Picture src={img1} alt="" layout="full-width" />
            </div>
            <div class="hero-slide" style="z-index: 4; animation-delay: 4s" aria-hidden="true">
                <Picture src={img2} alt="" layout="full-width" />
            </div>
            <div class="hero-slide" style="z-index: 3; animation-delay: 8s" aria-hidden="true">
                <Picture src={img3} alt="" layout="full-width" />
            </div>
            <div class="hero-slide" style="z-index: 2; animation-delay: 12s" aria-hidden="true">
                <Picture src={img4} alt="" layout="full-width" />
            </div>
            <div class="hero-slide" style="z-index: 1; animation-delay: 16s" aria-hidden="true">
                <Picture src={img5} alt="" layout="full-width" />
            </div>
        </div>
        <!-- Overlay for text legibility -->

        <!-- Foreground content -->
        <div class="relative z-10">
            <RevealHeader
                delay={0.25}
                textColor={'#FFFFFF'}
                lines={[
                    { text: 'Concrétisez votre', font: 'formula' },
                    { text: 'Leadership', font: 'editorial' },
                    { text: 'Authentique', font: 'editorial' }
                ]}
            />
        </div>
    </div>

    <div
        class="desktop-version grid h-fit min-h-[500px] grid-cols-12 gap-fluid-twenty bg-offwhite pt-fluid-eighty pr-fluid-forty pb-fluid-eighty pl-fluid-forty"
    >
        <div class="col-span-4 min-h-full overflow-clip pr-fluid-twenty">
            <RevealImage>
                <Picture
                    src={chalkboard}
                    class="aspect-444/668 min-h-[500px] object-cover"
                    layout="full-width"
                    alt="chalkboard"
                />
            </RevealImage>
        </div>
        <div class="col-span-8 flex grow flex-col">
            <div
                class="font-radio lg:text-body flex flex-row items-center justify-center border-b border-b-perle pb-3 text-mob-section tracking-[3%] uppercase"
            >
                À Propos
            </div>
            <div
                class="desktop-version flex grow flex-col justify-between pt-fluid-eighty pr-[3.78rem] pl-[3.78rem]"
            >
                <p class="text-test leading-[120%] font-light tracking-[3%]">
                    <span class="font-bold text-bronze">Tangible</span> révèle le leadership authentique
                    des entrepreneurs et des équipes exécutives. Notre approche intégrée allie coaching
                    sur mesure, outils innovants et ateliers immersifs. Fondée sur la connexion humaine,
                    la confiance et l’intelligence collective, elle crée des espaces de transformation
                    durables et porteurs de sens.
                </p>
            </div>
            <div
                class="desktop-version flex w-full flex-row items-center justify-center pb-fluid-forty"
            >
                <Button class="text-body-sm tracking-[3%] uppercase">En savoir plus</Button>
            </div>
        </div>
    </div>

    <div class="mob-version grid h-fit min-h-[500px] grid-cols-8 gap-mob-16 bg-offwhite p-mob-16">
        <div
            class="font-radio col-span-8 flex flex-row items-center justify-center border-b border-b-perle pt-mob-64 pr-mob-16 pb-mob-16 pl-mob-16 text-mob-section tracking-[3%] uppercase"
        >
            À Propos
        </div>
        <div class="col-span-6 col-start-2 min-h-full overflow-clip pt-mob-64">
            <RevealImage>
                <Picture
                    src={chalkboard}
                    class="aspect-267/343 object-cover"
                    layout="full-width"
                    alt="chalkboard"
                />
            </RevealImage>
        </div>
        <div class="col-span-8 flex flex-col pt-mob-64 pb-mob-64">
            <div class="flex flex-col gap-mob-32">
                <p class="text-mob-body leading-[120%] font-light tracking-[3%]">
                    <span class="font-bold text-bronze">Tangible</span> révèle le leadership authentique
                    des entrepreneurs et des équipes exécutives. Notre approche intégrée allie coaching
                    sur mesure, outils innovants et ateliers immersifs. Fondée sur la connexion humaine,
                    la confiance et l’intelligence collective, elle crée des espaces de transformation
                    durables et porteurs de sens.
                </p>
                <div class="flex w-full flex-row items-center justify-center">
                    <Button class="text-body-sm tracking-[3%] uppercase">En savoir plus</Button>
                </div>
            </div>
        </div>
    </div>

    <div
        class="desktop-version grid h-fit grid-cols-12 items-center justify-center gap-fluid-twenty bg-yellow pt-fluid-eighty pr-fluid-forty pb-fluid-eighty pl-fluid-forty"
    >
        <h1
            class="heading-lg font-radio col-span-6 col-start-2 flex h-full flex-col justify-center leading-[105%] font-normal tracking-[0%]"
