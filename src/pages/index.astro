    </div>

    <div class="mob-version flex h-fit flex-col bg-offwhite pt-mob-64 pr-mob-16 pl-mob-16">
        <div
            class="font-radio flex w-full flex-row items-center justify-center border-b border-b-perle pb-3 text-body-sm tracking-[3%] uppercase"
        >
            Nos programmes
        </div>
        <div
            class="relative grid grid-cols-8 gap-mob-16 border-b border-perle bg-offwhite pt-fluid-forty"
        >
            <div class="col-span-8 pt-mob-64 pb-mob-16">
                <RevealHeader
                    lines={[
                        { text: 'Coaching', font: 'formula' },
                        { text: 'D’Entreprises', font: 'editorial' }
                    ]}
                />
            </div>
            <Image src={chalkboard} class="aspect-267/367.43 col-span-6 col-start-2" />
            <div class="col-span-6 col-start-2 flex flex-col justify-start gap-0 pt-mob-16">
                <p class="pb-fluid-forty text-mob-caption leading-[120%] tracking-[3%]">
                    Le leadership d’entreprise ne s’improvise pas. Il se cultive. Découvrez nos
                    programmes conçus pour les dirigeant·es, gestionnaires et équipes internes de
                    moyennes et grandes organisations. Nous offrons un accompagnement individuel et
                    de groupe de haute qualité pour incarner un leadership à la fois humain,
                    stratégique et pérenne. Nos feuilles de route sur mesure associent ateliers
                    d’expert·es, outils psychométriques, coaching exécutif et ateliers collaboratifs
                    pour générer des dynamiques puissantes fondées sur l’intelligence collective.
                    <br />
                    <br />
                    <span class="font-bold text-bronze">Résultat</span> : une clarté renforcée, une cohésion
                    amplifiée et un impact durable.
                </p>
                <div class="flex w-full flex-row items-center justify-center pt-mob-16 pb-mob-64">
                    <Button class="text-body-sm tracking-[3%] uppercase">En savoir plus</Button>
                </div>
            </div>
        </div>
        <div
            class="relative grid grid-cols-8 gap-mob-16 border-b border-perle bg-offwhite pt-fluid-forty"
        >
            <div class="col-span-8 pt-mob-64 pb-mob-16">
                <RevealHeader
                    lines={[
                        { text: 'Coaching', font: 'formula' },
                        { text: 'Des leaders', font: 'editorial' }
                    ]}
                />
            </div>
            <Image src={chalkboard} class="aspect-267/367.43 col-span-6 col-start-2" />
            <div class="col-span-6 col-start-2 flex flex-col justify-start gap-0 pt-mob-16">
                <p class="pb-fluid-forty text-mob-caption leading-[120%] tracking-[3%]">
                    Le leadership d’entreprise ne s’improvise pas. Il se cultive. Découvrez nos
                    programmes conçus pour les dirigeant·es, gestionnaires et équipes internes de
                    moyennes et grandes organisations. Nous offrons un accompagnement individuel et
                    de groupe de haute qualité pour incarner un leadership à la fois humain,
                    stratégique et pérenne. Nos feuilles de route sur mesure associent ateliers
                    d’expert·es, outils psychométriques, coaching exécutif et ateliers collaboratifs
                    pour générer des dynamiques puissantes fondées sur l’intelligence collective.
                    <br />
                    <br />
                    <span class="font-bold text-bronze">Notre ambition</span> : du sens, de l’impact,
                    de la cohérence.
                </p>
                <div class="flex w-full flex-row items-center justify-center pt-mob-16 pb-mob-64">
                    <Button class="uppercase">En savoir plus</Button>
                </div>
            </div>
        </div>
    </div>

    <div
        class="desktop-version relative grid h-fit grid-cols-12 gap-fluid-twenty bg-offwhite pt-fluid-eighty pr-fluid-forty pb-fluid-forty pl-fluid-forty"
    >
        <div class="col-span-4 flex flex-col overflow-clip pr-fluid-twenty">
            <Image src={chalkboard} class="h-full" />
        </div>
        <div
            class="col-span-8 flex h-full flex-col items-start gap-fluid-forty overflow-hidden border-b border-b-perle pr-fluid-sixty pl-fluid-sixty"
        >
            <RevealHeader
                lines={[
                    { text: 'Coaching', font: 'formula' },
                    { text: 'D’Entreprises', font: 'editorial' }
                ]}
            />
            <div class="flex flex-col justify-end gap-0">
                <p class="pb-fluid-forty text-body-caption leading-[120%] tracking-[3%]">
                    Le leadership d’entreprise ne s’improvise pas. Il se cultive. Découvrez nos
                    programmes conçus pour les dirigeant·es, gestionnaires et équipes internes de
                    moyennes et grandes organisations. Nous offrons un accompagnement individuel et
                    de  groupe de haute qualité pour incarner un leadership à la fois humain,
                    stratégique et pérenne. Nos feuilles de route sur mesure associent ateliers
                    d’expert·es, outils psychométriques, coaching exécutif et ateliers collaboratifs
                    pour générer des dynamiques puissantes fondées sur l’intelligence collective.
                    <br />
                    <br />
                    <span class="font-bold text-bronze">Résultat</span> : une clarté renforcée, une cohésion
                    amplifiée et un impact durable.
                </p>
                <div class="flex w-full flex-row items-center justify-center pb-fluid-forty">
                    <Button class="text-body-sm tracking-[3%] uppercase">En savoir plus</Button>
                </div>
            </div>
        </div>
    </div>

    <div
        class="desktop-version relative grid h-fit grid-cols-12 gap-fluid-twenty border-b border-b-perle bg-offwhite pt-fluid-eighty pr-fluid-forty pb-fluid-eighty pl-fluid-forty"
    >
        <div
            class="col-span-8 flex h-full flex-col items-start gap-fluid-forty overflow-hidden pr-fluid-sixty pl-fluid-sixty"
        >
            <RevealHeader
                lines={[
                    { text: 'Coaching', font: 'formula' },
                    { text: 'De Leaders', font: 'editorial' }
                ]}
            />
            <div class="flex flex-col justify-end gap-0">
                <p class="pb-fluid-forty text-body-caption leading-[120%] tracking-[3%]">
                    Un leadership authentique commence par un alignement intérieur. Entrepreneurs,
                    professionnel·les en mouvement, coachs certifiés — nos programmes vous
                    accompagnent pour incarner un leadership aligné sur vos valeurs et votre
                    mission, à la fois humain et performant. Coaching individuel, outils
                    psychométriques, cercles de co-apprentissage entre leaders : une approche sur
                    mesure dans un cadre stratégique, stimulant et bienveillant.
                    <br />
                    <br />
                    <span class="font-bold text-bronze">Notre ambition</span> : du sens, de l’impact,
                    de la cohérence.
                </p>
                <div class="flex w-full flex-row items-center justify-center pb-fluid-forty">
                    <Button class="text-body-sm tracking-[3%] uppercase">En savoir plus</Button>
                </div>
            </div>
        </div>
        <div class="col-span-4 overflow-clip pl-fluid-twenty">
            <Image src={chalkboard} class="aspect-444/668 h-full" />
        </div>
    </div>

    <ContactFooter heading="Amorcez une transformation tangible." />
</Layout>

<style>
    /* ─── Hero Slideshow ────────────────────────────────────────────── */
    .hero-section {
        background: #1a1a1a; /* fallback while images load */
    }

    .hero-slideshow {
        position: absolute;
        inset: 0;
        z-index: 0;
    }

    /*
     * Each slide fills the container. All start fully opaque (opacity: 1 is
     * the CSS default, applied BEFORE the delayed animation begins).
     * The animation fades the slide OUT to reveal the one beneath it.
     * z-index stacking: img1 on top → img5 at the bottom.
     */
    .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 1; /* visible by default; animation will fade it out */
        animation: hero-fade 20s ease-out infinite;
    }

    /* The picture + img inside each wrapper fill the space */
    :global(.hero-slide picture),
    :global(.hero-slide img) {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        z-index: 6; /* above all 5 slides */
        background: rgba(0, 0, 0, 0.35);
        pointer-events: none;
    }

    /*
     * 5 images × 4s per image = 20s total cycle.
     * Each image: hold 3s (0%→15%), fade out over 1s (15%→20%),
     * stay transparent (20%→95%), then gently fade back in (95%→100%, 1s).
     * The 1s fade-in (95%→100%) overlaps perfectly with the previous
     * image's 1s fade-out (15%→20%), making every loop restart seamless.
     */
    @keyframes hero-fade {
        0% {
            opacity: 1;
        } /* hold — current image is shown  */
        15% {
            opacity: 1;
        } /* hold for ~3s                   */
        20% {
            opacity: 0;
        } /* fade out over ~1s              */
        95% {
            opacity: 0;
        } /* stay hidden while others cycle */
        100% {
            opacity: 1;
        } /* smooth 1s fade-in to be ready  */
    }
</style>
