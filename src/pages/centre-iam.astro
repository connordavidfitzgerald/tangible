---
import Layout from '@layouts/Layout.astro';

import { Picture } from 'astro:assets';
import FadeUp from '@components/FadeUp/FadeUp.astro';
import RevealHeader from '@components/RevealHeader/RevealHeader.astro';
import ContactFooter from '@components/ContactFooter/ContactFooter.astro';
import RevealImage from '@components/RevealHeader/RevealImage.astro';
import RevealBody from '@components/RevealHeader/RevealBody.astro';
import SplitReveal from '@components/SplitReveal/SplitReveal.astro';
import ServiceSlider from '@components/ServiceSlider/ServiceSlider.astro';
import ServiceSliderAlt from '@components/ServiceSlider/ServiceSliderAlt.astro';

import about from '@images/centreiam2.png';
import leaders from '@images/hands_tangible.jpg';
import mobcentre from '@images/mob_centre.png';
import mob from '@images/hands.jpg';
---

<Layout title="I AM Center">
    <div
        class="flex aspect-393/852 max-h-dvh flex-col justify-end bg-offwhite pr-fluid-forty pl-fluid-forty md:aspect-1512/902 md:justify-center md:pb-0"
    >
        <div class="absolute right-0 left-0 z-0 aspect-393/852 md:aspect-1512/902">
            <Picture
                alt="A clipboard and paper"
                src={leaders}
                layout="full-width"
                class="hidden h-full w-full object-cover md:flex"
            />
            <Picture
                alt="A clipboard and paper"
                src={mob}
                layout="full-width"
                class="flex h-full w-full object-cover md:hidden"
            />
        </div>
        <div class="w-full pb-fluid-160 md:pb-0">
            <RevealHeader
                delay={0.25}
                textColor="#FFFFFF"
                lines={[
                    { text: 'Pour une connexion', font: 'formula' },
                    { text: 'authentique', font: 'editorial' },
                    { text: 'à son étre', font: 'editorial' }
                ]}
            />
        </div>
    </div>

    <div
        class="grid aspect-1512/830 h-fit w-full grid-cols-8 items-center bg-offwhite px-fluid-forty pt-fluid-eighty md:grid-cols-12 md:gap-fluid-twenty"
    >
        <div
            class="font-radio col-span-8 flex w-full flex-row items-center justify-center border-b border-b-perle pb-3 text-[0.875rem] tracking-[3%] uppercase md:hidden md:text-[1rem]"
        >
            À Propos
        </div>
        <div
            class="col-span-6 col-start-2 hidden w-full md:col-span-4 md:col-start-1 md:flex md:pr-fluid-twenty"
        >
            <FadeUp>
                <Picture src={about} alt="Ron Cherilus" class="h-auto w-full object-cover" />
            </FadeUp>
        </div>
        <div
            class="col-span-6 col-start-2 flex w-full pt-16 pb-16 md:col-span-4 md:col-start-1 md:hidden md:pl-0"
        >
            <FadeUp>
                <Picture src={mobcentre} alt="Ron Cherilus" class="h-auto w-full object-cover" />
            </FadeUp>
        </div>
        <div
            class="col-span-8 flex h-full w-full flex-col items-center justify-start gap-fluid-eighty border-b border-b-perle"
        >
            <div
                class="font-radio hidden w-full flex-row items-center justify-center border-b border-b-perle pb-3 text-[1rem] tracking-[3%] uppercase md:flex"
            >
                À Propos
            </div>
            <p
                class="pb-16 text-mob-body leading-[120%] font-light tracking-[3%] md:pr-fluid-sixty md:pl-fluid-sixty md:text-body-md"
            >
                Depuis 2012, le Centre I AM accompagne des milliers de membres vers la réalisation
                de leur ÊTRE authentique. Établi au cœur du centre-ville, dans un espace à la fois
                inspirant et unique, le Centre I AM est un lieu de rencontres humaines où
                formations, services de coaching et méditations sont offerts. Guidé par une équipe
                de coach·es professionnel·les certifié·es, le Centre I AM propose des
                accompagnements  pour développer votre autonomie, cultiver votre présence à soi et
                incarner un plus grand épanouissement dans toutes les sphères de votre vie.
            </p>
        </div>
        <div
            class="font-radio col-span-12 flex flex-row items-center justify-center border-b border-b-perle pt-16 pb-3 text-[0.875rem] tracking-[3%] uppercase md:pt-fluid-eighty md:text-[1rem]"
        >
            Nos services CIAM
        </div>
    </div>

    <div class="flex h-4 bg-offwhite"></div>
    <ServiceSliderAlt
        slides={[
            {
                shapeClass: 'starburst',
                shapeTitle: 'Formations',
                descriptions: [
                    {
                        text: 'Nos coachs certifié·es vous accompagnent dans l’émergence du leader authentique en vous. Nos formations proposent de découvrir et d’intégrer la posture du leader-coach. En partant de l’essence (l’alignement intérieur, la clarté, l’intention), les participant·es apprendront à transformer leur leadership en une pratique tangible, vécue dans leurs conversations quotidiennes, leurs décisions et leur façon de mobiliser leurs équipes.'
                    }
                ]
            },
            {
                shapeClass: 'diamond',
                shapeTitle: 'Coaching',
                descriptions: [
                    {
                        text: 'Nos services de coaching offrent des expériences personnalisées et transformatrices, en individuel ou en groupe. Ces rencontres vous permettent de faire le point, de vous aligner sur votre I AM et d’accéder à un niveau supérieur de clarté, de congruence et de confiance en vous, tant dans vos décisions que dans vos relations.'
                    }
                ]
            },
            {
                shapeClass: 'sparkle',
                shapeTitle: 'Méditation',
                descriptions: [
                    {
                        text: 'Nos expert·es et professeur·es vous initient à diverses techniques de méditation basées sur des approches scientifiques et des méthodes immersives. Grâce à des outils comme les intégrations musicales, nous vous aidons à vous recentrer, calmer le mental et retrouver votre pleine puissance intérieure.'
                    }
                ]
            },
            {
                shapeClass: 'circle',
                shapeTitle: 'Coaching de<br/>prise de parole',
                descriptions: [
                    {
                        text: 'S’exprimer librement en public, c’est souvent sortir de sa zone de confort. Le coaching I AM vous aide à le faire avec authenticité, assurance et liberté. Nos accompagnements allient approche introspective et volet technique: vous explorez le récit personnel qui donne sens à votre message, tout en développant votre présence, votre aisance, votre éloquence et votre maîtrise de la parole. Une démarche complète pour vous aligner, incarner votre histoire et communiquer avec impact.'
                    }
                ]
            },
            {
                shapeClass: 'hexagon',
                shapeTitle: 'Nos services<br/>pro bono',
                descriptions: [
                    {
                        text: 'Pour accroître notre impact social, l’équipe de coaching I AM offre ses services pro bono à des organismes à but non lucratif (OBNL) qui ont une mission sociale, environnementale, sportive ou éducative auprès des jeunes. Une façon concrète de mettre notre expertise au service de ceux et celles qui bâtissent un monde meilleur.'
                    }
                ]
            }
        ]}
    />

    <ContactFooter heading="Amorcez une transformation tangible." />
</Layout>
