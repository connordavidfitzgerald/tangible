---
import Layout from '@layouts/Layout.astro';
import Button from '@components/Button/Button.astro';
import Image from '@components/Image/Image.astro';
import { Picture } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import chalkboard from '@images/Home_about.jpg';
import RevealHeader from '@components/RevealHeader/RevealHeader.astro';
import ContactFooter from '@components/ContactFooter/ContactFooter.astro';
import RevealImage from '@components/RevealHeader/RevealImage.astro';
import RevealBody from '@components/RevealHeader/RevealBody.astro';
import SplitReveal from '@components/SplitReveal/SplitReveal.astro';

import img6 from '@images/Tangible0797.jpg';
import img7 from '@images/LEADER.jpg';
---

<Layout title="Programs">
    <div
        class="relative grid grid-cols-8 gap-fluid-twenty bg-offwhite pt-fluid-eighty pr-fluid-forty pl-fluid-forty sm:grid-cols-12"
    >
        <div
            class="col-span-8 flex flex-col pt-30 pr-fluid-sixty pb-16 pl-fluid-sixty sm:col-start-3 sm:pt-fluid-eighty sm:pb-fluid-eighty"
        >
            <h1 class="text-center text-list-lg leading-[120%] text-bronze">
                Our programs for tangible results
            </h1>
        </div>
    </div>
    <!-- Sticky scroll section -->
    <!-- Both cards are h-screen so the wrapper is naturally 200vh.
         Card 1 pins (sticky) while card 2 scrolls in over it in normal flow. -->
    <programs-animation style="display: contents;">
        <div class="programs-scroll-wrapper relative bg-offwhite">
            <!-- Card 1: pins to the top while card 2 scrolls past -->
            <div
                class="programs-card programs-card-1 sm:h-200vh relative top-0 z-10 grid h-fit grid-cols-8 gap-fluid-twenty bg-perle pt-fluid-eighty pr-fluid-forty pb-fluid-eighty pl-fluid-forty sm:sticky sm:grid-cols-12"
            >
                <div class="col-span-4 hidden overflow-clip sm:flex">
                    <Image src={img6} class="aspect-444/668 h-full" />
                </div>
                <div
                    class="col-span-8 grid h-full grid-cols-8 items-start justify-between gap-fluid-twenty pt-16 sm:flex sm:flex-col sm:gap-fluid-forty sm:pt-0 sm:pr-fluid-sixty sm:pl-fluid-sixty"
                >
                    <div class="col-span-8 pb-8 sm:pb-0">
                        <RevealHeader
                            delay={0.25}
                            lines={[
                                { text: 'Corporate', font: 'formula' },
                                { text: 'Coaching', font: 'editorial' }
                            ]}
                        />
                    </div>

                    <div class="col-span-6 col-start-2 flex aspect-267/367 overflow-clip sm:hidden">
                        <Image src={img6} class="sm:aspect-444/668" />
                    </div>
                    <div class="col-span-6 col-start-2 flex flex-col justify-end gap-0">
                        <p
                            class="pt-8 pb-fluid-forty text-body-caption leading-[120%] tracking-[3%] sm:pt-0"
                        >
                            Corporate leadership is not improvised. It is cultivated. Discover our
                            programs designed for executives, managers, and internal teams of medium
                            and large organizations. We offer high-quality individual and group
                            support to embody leadership that is both human, strategic, and lasting.
                            Our tailor-made roadmaps combine expert workshops, psychometric tools,
                            executive coaching, and collaborative workshops to generate powerful
                            dynamics based on collective intelligence.
                            <br />
                            <br />
                            <span class="font-bold text-bronze">Result</span>: enhanced clarity,
                            amplified cohesion, and lasting impact.
                        </p>
                        <div
                            class="flex w-full flex-row items-center justify-center pt-4 pb-fluid-160 sm:pt-0 sm:pb-0"
                        >
                            <Button
                                class="text-body-sm tracking-[3%] uppercase"
                                href="/en/programs/entreprises">Learn more</Button
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 2: normal flow, scrolls in on top of the sticky card 1 -->
            <div
                class="programs-card-2 relative z-20 grid h-fit grid-cols-8 gap-fluid-twenty bg-bronze pt-16 pr-fluid-forty pb-fluid-eighty pl-fluid-forty text-perle sm:grid-cols-12 sm:pt-fluid-eighty"
            >
                <div
                    class="col-span-8 grid h-full grid-cols-8 gap-fluid-twenty pl-fluid-sixty sm:flex sm:flex-col sm:justify-between sm:pr-fluid-sixty"
                >
                    <div class="col-span-8 flex w-full flex-col pt-fluid-forty">
                        <RevealHeader
                            textColor={'#e1e3d0'}
                            lines={[
                                { text: 'Leader', font: 'formula' },
                                { text: 'Coaching', font: 'editorial' }
                            ]}
                        />
                    </div>
                    <div
                        class="col-span-6 col-start-2 flex aspect-267/367 overflow-clip pt-8 sm:hidden sm:pt-0"
                    >
                        <Image src={img7} class="sm:aspect-444/668" />
                    </div>
                    <div class="col-span-6 col-start-2 flex flex-col justify-end gap-0">
                        <p
                            class="pt-8 pb-fluid-forty text-body-caption leading-[120%] tracking-[3%] sm:pt-0"
                        >
                            Authentic leadership begins with inner alignment. Entrepreneurs,
                            professionals in motion, certified coaches — our programs support you in
                            embodying leadership aligned with your values and your mission, both
                            human and high-performing. Individual coaching, psychometric tools,
                            co-learning circles between leaders: a tailor-made approach in a
                            strategic, stimulating, and caring environment.
                            <br />
                            <br />
                            <span class="font-bold">Our ambition</span>: meaning, impact, coherence.
                        </p>
                        <div
                            class="flex w-full flex-row items-center justify-center pt-4 pb-fluid-160 sm:pt-0 sm:pb-0"
                        >
                            <Button
                                class="text-body-sm tracking-[3%] uppercase"
                                href="/en/programs/leaders">Learn more</Button
                            >
                        </div>
                    </div>
                </div>
                <div class="col-span-4 hidden overflow-clip sm:flex">
                    <Image src={img7} class="aspect-444/668 h-full" />
                </div>
            </div>
        </div>
    </programs-animation>
    <div
        class="flex flex-col justify-center bg-offwhite pt-65 pr-fluid-forty pb-65 pl-fluid-forty text-bronze sm:aspect-1512/902 sm:pt-0 sm:pb-0"
    >
        <div class="grid h-fit grid-cols-12">
            <div
                class="col-span-12 flex flex-col gap-fluid-forty border-t border-b border-bronze pt-fluid-forty pb-fluid-forty sm:col-span-10 sm:col-start-2"
            >
                <SplitReveal class="text-list-lg leading-[120%]">
                    « Through each encounter, a movement is created: one that aligns the human, the
                    mission, and the impact. »
                </SplitReveal>
                <div class="grid grid-cols-2 gap-0">
                    <p class="col-span-1 col-start-2 text-mob-body font-light sm:text-test">
                        — Ron Chérilus
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script>
        import { gsap } from 'gsap';
        import { ScrollTrigger } from 'gsap/ScrollTrigger';
        gsap.registerPlugin(ScrollTrigger);

        class ProgramsAnimation extends HTMLElement {
            private mm: gsap.MatchMedia | undefined;

            connectedCallback() {
                const card1 = this.querySelector('.programs-card-1') as HTMLElement | null;
                const card2 = this.querySelector('.programs-card-2') as HTMLElement | null;

                if (card1 && card2) {
                    this.mm = gsap.matchMedia();

                    this.mm.add('(min-width: 700px)', () => {
                        // card2 is in normal flow directly after card1 (both are h-screen).
                        // As card2 scrolls in from the bottom, scale card1 down.
                        gsap.to(card1, {
                            scale: 0.8,
                            ease: 'none',
                            scrollTrigger: {
                                trigger: card2,
                                start: 'top 100%', // card2's top hits the bottom of the viewport
                                end: 'top top', // card2's top reaches the top (fully overlapping)
                                scrub: true
                            }
                        });
                    });
                }
            }

            disconnectedCallback() {
                this.mm?.revert();
            }
        }

        if (!customElements.get('programs-animation')) {
            customElements.define('programs-animation', ProgramsAnimation);
        }
    </script>
    <ContactFooter lang="en" heading="Initiate a tangible transformation." />
</Layout>
