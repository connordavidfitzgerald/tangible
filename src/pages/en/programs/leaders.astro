---
import Layout from '@layouts/Layout.astro';

import { Picture } from 'astro:assets';

import RevealHeader from '@components/RevealHeader/RevealHeader.astro';
import ContactFooter from '@components/ContactFooter/ContactFooter.astro';
import RevealImage from '@components/RevealHeader/RevealImage.astro';
import RevealBody from '@components/RevealHeader/RevealBody.astro';
import SplitReveal from '@components/SplitReveal/SplitReveal.astro';
import ServiceSlider from '@components/ServiceSlider/ServiceSlider.astro';

import leaders from '@images/leaders.jpg';
---

<Layout title="Programs — Leaders">
    <div class="flex h-screen flex-col justify-center bg-offwhite pr-fluid-forty pl-fluid-forty">
        <div class="absolute top-0 right-0 left-0 z-0 h-full w-full">
            <Picture
                alt="A clipboard and paper"
                src={leaders}
                layout="full-width"
                class="h-full min-w-full object-cover"
            />
        </div>
        <RevealHeader
            delay={0.25}
            textColor="#FFFFFF"
            lines={[
                { text: 'Leader', font: 'formula' },
                { text: 'Coaching', font: 'editorial' }
            ]}
        />
    </div>
    <div
        class="grid aspect-1512/830 h-fit grid-cols-12 gap-fluid-twenty bg-offwhite pt-fluid-5xl pr-fluid-forty pb-fluid-5xl pl-fluid-forty"
    >
        <div
            class="col-span-12 flex h-full flex-col justify-center gap-fluid-eighty pt-16 pb-16 sm:col-span-8 sm:col-start-3 sm:pt-0 sm:pb-0"
        >
            <p class="text-mob-body leading-[120%] font-light tracking-[3%] sm:text-body-md">
                Our programs dedicated to leaders support entrepreneurs, coaches, and professionals
                in transition or growth. They are designed to support aligned, human, and
                sustainable leadership through individual, group, and immersive paths.
            </p>
        </div>
    </div>

    <ServiceSlider
        slides={[
            {
                shapeClass: 'hexagon',
                shapeTitle: 'Individual<br/>Programs',
                descriptions: [
                    {
                        title: 'Propulse',
                        text: 'Activation coaching for emerging leaders. To take action with clarity and structure the first foundations of your project.'
                    },
                    {
                        title: 'Growth+',
                        text: 'Structuring coaching for entrepreneurs in expansion. To consolidate your posture, clarify your vision, and create a sustainable strategic impact.'
                    },
                    {
                        title: 'Strategic Focus',
                        text: 'For seasoned mentors and founders in the phase of transmission, transition, or refocusing. Includes the GLP (Global Leadership Profile).'
                    }
                ]
            },
            {
                shapeClass: 'circle',
                shapeTitle: 'Group<br/>Programs',
                descriptions: [
                    {
                        title: 'NEOSPHÈRE – The network of entrepreneurs open to opportunities',
                        text: 'A transformational collective program for leaders seeking meaning. Between guided introspection, entrepreneurial alignment, and collective activation, NEOSPHÈRE offers a supportive, strategic, and deeply human space.'
                    }
                ]
            },
            {
                shapeClass: 'diamond',
                shapeTitle: 'Immersive<br/>Experiences',
                descriptions: [
                    {
                        title: 'Tangible Circles',
                        text: 'Monthly subscriptions providing access to exclusive content, group coaching, and an engaged community. Three formats: Co-creation, Anchoring, and Expansion.'
                    },
                    {
                        title: 'Whiteboard™',
                        text: 'Intensive workshops to clarify your entrepreneurial trajectory, facilitate key decisions, and revive your strategic vision.'
                    },
                    {
                        title: 'Tangible Retreats',
                        text: 'Human immersions for leaders and regenerative spaces for leaders seeking refocusing, alignment, and resourcing — in nature or in the city.'
                    }
                ]
            }
        ]}
    />

    <ContactFooter heading="Initiate a tangible transformation." />
</Layout>
