---
import Layout from '@layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { Picture } from 'astro:assets';
import RevealHeader from '@components/RevealHeader/RevealHeader.astro';
import SplitReveal from '@components/SplitReveal/SplitReveal.astro';
import ronCherilus from '../assets/images/roncherilus.jpg';
import ContactFooter from '../components/ContactFooter/ContactFooter.astro';
---

<Layout title="À Propos">
    <div
        class="hero-section sm: relative flex h-fit flex-col justify-start overflow-hidden bg-bronze pt-32 pr-fluid-forty pb-fluid-270 pl-fluid-forty sm:max-h-300 sm:min-h-200 sm:justify-start sm:gap-32 sm:pb-0"
    >
        <div
            class="font-radio lg:text-body flex flex-row items-center justify-center border-b border-b-perle pb-3 text-mob-section tracking-[3%] text-perle uppercase"
        >
            Mission
        </div>
        <div
            class="relative w-full pt-16 pb-20 sm:absolute sm:top-1/2 sm:right-fluid-twenty sm:w-[45%] sm:min-w-[450px] sm:-translate-y-1/2 sm:pt-32 sm:pb-0"
        >
            <Icon name="hands" class="h-auto w-full mix-blend-multiply" />
        </div>
        <RevealHeader
            delay={0.25}
            textColor={'#E1E3D0'}
            lines={[
                { text: 'Tangible: Rélever', font: 'formula' },
                { text: 'la pleine puissance', font: 'formula' },
                { text: 'des leaders', font: 'editorial' },
                { text: 'et des equipes.', font: 'editorial' }
            ]}
        />
    </div>
    <div
        class="grid h-fit grid-cols-8 gap-mob-16 bg-perle pt-mob-128 pr-mob-16 pb-mob-128 pl-mob-16 md:min-h-[900px] md:grid-cols-12 md:gap-fluid-twenty md:pt-0 md:pr-fluid-forty md:pb-0 md:pl-fluid-forty"
    >
        <div
            class="col-span-8 flex h-full flex-col justify-center gap-fluid-eighty md:col-span-8 md:col-start-3"
        >
            <p
                class="border-b border-b-white pb-mob-32 text-mob-body leading-[120%] font-light tracking-[3%] md:border-none md:pb-0 md:text-body-md"
            >
                <span class="font-bold text-bronze">Tangible</span> accompagne les leaders, équipes et
                entrepreneur·es en quête de sens, de cohérence et d’impact. Nos parcours sur mesure allient
                coaching, outils psychométriques, expériences immersives et ateliers pour faire émerger
                un leadership stratégique, humain et ancré.
            </p>
            <p
                class="pt-mob-16 text-mob-body leading-[120%] font-light tracking-[3%] md:pt-0 md:text-body-md"
            >
                Notre approche active les ressources individuelles et collectives pour naviguer la
                complexité du monde du travail avec clarté et agilité.
            </p>
        </div>
    </div>
    <div
        class="gap-y-mob-0 grid grid-cols-8 gap-mob-16 bg-offwhite pt-mob-64 pr-mob-16 pl-mob-16 md:grid-cols-12 md:gap-x-fluid-twenty md:gap-y-fluid-twenty md:pt-fluid-forty md:pr-fluid-forty md:pl-fluid-forty"
    >
        <div class="col-span-8 md:col-span-12">
            <div
                class="font-radio flex flex-row items-center justify-center border-b border-b-perle pb-mob-16 text-mob-section tracking-[3%] uppercase md:pb-fluid-twenty md:text-body-sm"
            >
                À Propos
            </div>
        </div>
        <circles-animation class="col-span-6 col-start-2 w-full md:col-start-4">
            <div class="circles-wrapper">
                <div class="circle c1">
                    <div class="yellow y1"></div>
                    <SplitReveal class="text-circles-text leading-[120%] text-black">
                        Alignement<br />Vertical
                    </SplitReveal>
                </div>
                <div class="circle c2">
                    <SplitReveal class="text-circles-text leading-[120%] text-black">
                        Direction<br />Strategique
                    </SplitReveal>
                </div>
                <div class="circle c3">
                    <div class="yellow y3"></div>
                    <SplitReveal class="text-circles-text leading-[120%] text-black">
                        Intégration<br />Évolutive
                    </SplitReveal>
                </div>
            </div>
        </circles-animation>
        <div
            class="col-span-6 col-start-2 -mt-mob-64 w-full pb-mob-128 text-mob-caption leading-[120%] tracking-[2%] md:col-start-4 md:mt-0 md:pb-fluid-270 md:text-body-caption"
        >
            Inspirée de la méthode I AM de Ron Cherilus, Tangible déploie trois étapes clés dans
            chacun de ses programmes: alignement vertical, direction stratégique et intégration
            évolutive. Un processus fluide pour se reconnecter à son intention, prendre des
            décisions avec justesse, et faire évoluer son leadership avec profondeur.
        </div>
    </div>
    <div
        class="relative flex h-fit flex-col justify-center gap-0 bg-bronze pt-mob-32 pr-mob-16 pb-mob-128 pl-mob-16 text-offwhite md:h-screen md:min-h-[1080px] md:gap-fluid-twenty md:pt-fluid-forty md:pr-fluid-forty md:pb-fluid-eighty md:pl-fluid-forty"
    >
        <div
            class="font-radio col-span-12 flex grow flex-row items-center justify-center border-b border-b-perle pb-mob-16 text-mob-section tracking-[3%] uppercase md:absolute md:top-10 md:right-fluid-forty md:left-fluid-forty md:pb-fluid-twenty md:text-body-sm"
        >
            Vision
        </div>
        <div class="relative grid h-auto grid-cols-12 gap-fluid-twenty pt-mob-128 md:pt-0">
            <div
                class="col-span-12 h-fit pt-mob-32 text-black md:col-span-7 md:pt-0 md:pr-fluid-sixty md:pl-fluid-forty"
            >
                <Icon name="faces" class="h-auto w-full mix-blend-multiply" />
            </div>
            <SplitReveal
                class="font-radio col-span-12 flex h-full w-full flex-col items-start justify-center pt-mob-128 text-mob-body leading-[120%] font-light tracking-[3%] md:col-span-4 md:pt-0 md:text-test"
            >
                <span class="text-left"
                    >Le leadership authentique s’enracine dans la clarté, la conscience de soi et la
                    responsabilité partagée. Il fait émerger des personnes et des collectifs
                    cohérents, impactants et profondément humains.</span
                >
            </SplitReveal>
        </div>
    </div>
    <div
        class="relative grid h-fit grid-cols-8 gap-y-mob-64 bg-perle pt-mob-32 pr-mob-16 pb-fluid-270 pl-mob-16 md:grid-cols-12 md:gap-y-fluid-270 md:pt-fluid-forty md:pr-fluid-forty md:pl-fluid-forty"
    >
        <div
            class="font-radio relative col-span-8 flex grow flex-row items-center justify-center border-b border-b-offwhite pb-mob-16 text-mob-section tracking-[3%] uppercase md:col-span-12 md:pb-fluid-twenty md:text-body-sm"
        >
            Notre promesse
        </div>
        <div class="relative col-span-8 flex flex-col items-center justify-center md:col-start-3">
            <div class="relative grid grid-cols-8">
                <p
                    class="col-span-6 col-start-2 w-[60%] pb-fluid-eighty text-header-two leading-[120%] font-normal tracking-[1%] xs:w-full"
                >
                    Chez Tangible, on s'engage à
                </p>
                <div
                    class="col-span-8 grid grid-cols-8 gap-fluid-twenty border-t border-offwhite pt-fluid-thirty pb-fluid-thirty"
                >
                    <div class="col-span-1 font-formula text-list-num text-bronze">
                        <h4>1</h4>
                    </div>
                    <SplitReveal class="col-span-7 pt-1 pr-fluid-twenty text-list-lg leading-[120%]"
                        >Ancrer chaque parcours avec présence et intention.</SplitReveal
                    >
                </div>
                <div
                    class="col-span-8 grid grid-cols-8 gap-fluid-twenty border-t border-offwhite pt-fluid-thirty pb-fluid-thirty"
                >
                    <div class="col-span-1 font-formula text-list-num text-bronze">
                        <h4>2</h4>
                    </div>
                    <SplitReveal class="col-span-7 pt-1 pr-fluid-twenty text-list-lg leading-[120%]"
                        >Nourrir la connexion, la collaboration et la co-création.</SplitReveal
                    >
                </div>
                <div
                    class="col-span-8 grid grid-cols-8 gap-fluid-twenty border-t border-offwhite pt-fluid-thirty pb-fluid-thirty"
                >
                    <div class="col-span-1 font-formula text-list-num text-bronze">
                        <h4>3</h4>
                    </div>
                    <SplitReveal class="col-span-7 pt-1 pr-fluid-twenty text-list-lg leading-[120%]"
                        >Créer des espaces où la vérité peut s’exprimer.</SplitReveal
                    >
                </div>
                <div
                    class="col-span-8 grid grid-cols-8 gap-fluid-twenty border-t border-b border-offwhite pt-fluid-thirty pb-fluid-thirty"
                >
                    <div class="col-span-1 font-formula text-list-num text-bronze">
                        <h4>4</h4>
                    </div>
                    <SplitReveal class="col-span-7 pt-1 pr-fluid-twenty text-list-lg leading-[120%]"
                        >Accompagner chaque croissance avec générosité.</SplitReveal
                    >
                </div>
                <div
                    class="col-span-8 grid grid-cols-8 gap-fluid-twenty border-b border-offwhite pt-fluid-thirty pb-fluid-thirty"
                >
                    <div class="col-span-1 font-formula text-list-num text-bronze">
                        <h4>5</h4>
                    </div>
                    <SplitReveal class="col-span-7 pt-1 text-list-lg leading-[120%]"
                        >Offrir des résultats tangibles et durables.</SplitReveal
                    >
                </div>
            </div>
        </div>
    </div>
    <div
        class="grid grid-cols-8 gap-fluid-twenty bg-offwhite pt-16 pr-fluid-forty pb-32 pl-fluid-forty sm:grid-cols-12 sm:pt-44 sm:pb-40"
    >
        <div class="col-span-7 col-start-2 flex flex-col sm:hidden">
            <h1 class="font-radio pb-5 text-list-lg leading-[120%] sm:pb-fluid-twenty">
                Ron Cherilus
            </h1>
            <h2
                class="font-radio border-t border-b border-bronze pt-8 pb-[20px] text-header-two leading-[120%] sm:pt-fluid-twenty sm:pb-fluid-twenty"
            >
                Fondateur de Tangible<br />et du Centre I AM
            </h2>
        </div>

        <div class="col-span-6 col-start-2 pt-16 sm:col-span-5 sm:col-start-0 sm:pt-0">
            <Picture src={ronCherilus} alt="Ron Cherilus" class="h-auto w-full object-cover" />
        </div>

        <div
            class="col-span-6 col-start-2 grid grid-cols-6 gap-fluid-twenty border-b border-bronze pt-16 pb-16 sm:hidden sm:pt-0 sm:pb-0"
        >
            <p
                class="col-span-6 pt-fluid-sixty pb-fluid-sixty text-body-caption leading-[120%] tracking-[3%]"
            >
                Coach de direction et fondateur du Centre I AM à Montréal en 2012, Ron Chérilus
                lance en 2025 Tangible, un collectif d’experts en accompagnement stratégique et
                humain au service des entreprises et des organisations.<br /><br />Tangible est un
                réseau de professionnel·les trié·es sur le volet : coachs, experts en leadership, en
                stratégie et en intelligence émotionnelle réuni·es pour créer les conditions d’une
                transformation réelle, concrète et durable.<br /><br />Fort de plus de 15 ans
                d’expérience, Ron conçoit, structure et facilite des espaces de réflexion et de
                décision à fort impact, où les personnes, les enjeux et les choix s’alignent. Il
                accompagne dirigeant·es, entrepreneur·es et équipes dans des moments clés de leur
                trajectoire : croissance, transformation, repositionnement ou prises de décisions
                majeures.<br /><br />Certifié par plusieurs programmes de pointe en développement du
                leadership (GLP, LCP, MPO), il allie clarté stratégique et travail intérieur
                profond. Créateur de la méthode I AM, il soutient l’émergence d’un leadership
                incarné, conscient et humain, au service de décisions tangibles, alignées et
                pérennes.
            </p>
        </div>

        <div class="col-span-6 col-start-7 hidden flex-col sm:flex">
            <h1 class="font-radio pb-fluid-twenty text-circles-text leading-[120%]">
                Ron Cherilus
            </h1>
            <h2
                class="font-radio border-t border-b border-bronze pt-fluid-twenty pb-fluid-twenty text-header-two leading-[120%]"
            >
                Fondateur de Tangible<br />et du Centre I AM
            </h2>
            <div class="grid grid-cols-6 gap-fluid-twenty border-b border-bronze">
                <p
                    class="col-span-6 pt-fluid-sixty pb-fluid-sixty text-body-caption leading-[120%] tracking-[3%] xl:col-span-4"
                >
                    Coach de direction et fondateur du Centre I AM à Montréal en 2012, Ron Chérilus
                    lance en 2025 Tangible, un collectif d’experts en accompagnement stratégique et
                    humain au service des entreprises et des organisations.<br /><br />Tangible est
                    un réseau de professionnel·les trié·es sur le volet : coachs, experts en
                    leadership, en stratégie et en intelligence émotionnelle réuni·es pour créer les
                    conditions d’une transformation réelle, concrète et durable.<br /><br />Fort de
                    plus de 15 ans d’expérience, Ron conçoit, structure et facilite des espaces de
                    réflexion et de décision à fort impact, où les personnes, les enjeux et les
                    choix s’alignent. Il accompagne dirigeant·es, entrepreneur·es et équipes dans
                    des moments clés de leur trajectoire : croissance, transformation,
                    repositionnement ou prises de décisions majeures.<br /><br />Certifié par
                    plusieurs programmes de pointe en développement du leadership (GLP, LCP, MPO),
                    il allie clarté stratégique et travail intérieur profond. Créateur de la
                    méthode I AM, il soutient l’émergence d’un leadership incarné, conscient et
                    humain, au service de décisions tangibles, alignées et pérennes.
                </p>
            </div>
        </div>
    </div>
    <ContactFooter heading="Initiez un changement concret." />
    <style>
        .circles-wrapper {
            --gap-pct: 20%; /* gap between circles as % of wrapper width */
            position: relative;
            width: 100%;
            /* height = 3 circles tall + 2 gaps, all derived from width via aspect-ratio */
            /* Each circle is 100% wide and 100% tall (square). Gap is 20% of width. */
            /* Total height = 3 * width + 2 * (0.2 * width) = 3.4 * width */
            aspect-ratio: 1 / 3.4;
            margin: 0 auto;
        }

        .circle {
            position: absolute;
            width: 100%;
            aspect-ratio: 1; /* height always equals width — stays a perfect circle */
            border-radius: 50%;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .c1 {
            top: 0;
            background: #997e4e;
            color: white;
            z-index: 2;
        }

        .c2 {
            /* 1 circle height (=100% width) + 1 gap (=20% width) = 120% */
            top: 29.41%; /* 120% of width / 3.4 (the aspect ratio divisor) */
            background: #e1e3d0;
            color: #333;
            z-index: 1;
        }

        .c3 {
            /* 2 * (circle + gap) = 240% of width = 58.82% of wrapper height */
            top: 58.82%;
            background: #a29a93;
            color: white;
            z-index: 2;
        }

        .yellow {
            position: absolute;
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: #f4e727;
            pointer-events: none;
        }
    </style>

    <script>
        import { gsap } from 'gsap';
        import { ScrollTrigger } from 'gsap/ScrollTrigger';
        gsap.registerPlugin(ScrollTrigger);

        class CirclesAnimation extends HTMLElement {
            private ctx: gsap.Context | undefined;
            private resizeTimer: ReturnType<typeof setTimeout> | undefined;

            connectedCallback() {
                const wrapper = this.querySelector('.circles-wrapper');
                const c1 = this.querySelector('.c1') as HTMLElement | null;
                const c2 = this.querySelector('.c2') as HTMLElement | null;
                const c3 = this.querySelector('.c3') as HTMLElement | null;
                const y1 = this.querySelector('.y1');
                const y3 = this.querySelector('.y3');

                if (!c1 || !c2 || !c3) return;

                const init = () => {
                    this.ctx?.revert();
                    this.ctx = gsap.context(() => {
                        const size = c1.offsetWidth;
                        const overlap = 0.25 * size;
                        const finalDist = size - overlap;

                        const c1Top = c1.offsetTop;
                        const c2Top = c2.offsetTop;
                        const c3Top = c3.offsetTop;
                        const c2CenterY = c2Top + size / 2;

                        gsap.set(y1, { top: c2Top - c1Top, left: 0 });
                        gsap.set(y3, { top: c2Top - c3Top, left: 0 });

                        const deltaC1 = c2CenterY - finalDist - (c1Top + size / 2);
                        const deltaC3 = c3Top + size / 2 - (c2CenterY + finalDist);

                        const tl = gsap.timeline({
                            scrollTrigger: {
                                trigger: wrapper,
                                start: 'top 40%'
                            }
                        });

                        tl.to(c1, { y: deltaC1, duration: 1.2, ease: 'power3.inOut' }, 0);
                        tl.to(y1, { y: -deltaC1, duration: 1.2, ease: 'power3.inOut' }, 0);
                        tl.to(c3, { y: -deltaC3, duration: 1.2, ease: 'power3.inOut' }, 0);
                        tl.to(y3, { y: deltaC3, duration: 1.2, ease: 'power3.inOut' }, 0);
                    });
                };

                init();

                const onResize = () => {
                    clearTimeout(this.resizeTimer);
                    this.resizeTimer = setTimeout(init, 250);
                };
                window.addEventListener('resize', onResize);
            }

            disconnectedCallback() {
                this.ctx?.revert();
                clearTimeout(this.resizeTimer);
            }
        }

        if (!customElements.get('circles-animation')) {
            customElements.define('circles-animation', CirclesAnimation);
        }
    </script>
</Layout>
